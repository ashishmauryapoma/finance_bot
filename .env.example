
# ── Telegram ──────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Bot Password ──────────────────────────────
BOT_PASSWORD=your_secret_password_here

# ── Groq AI ───────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Google Sheets ─────────────────────────────
GOOGLE_CREDENTIALS_PATH=credentials.json
SPREADSHEET_ID=your_google_spreadsheet_id_here
SHEET_NAME=Transactions

# ── Webhook URL (Render deployment only) ──────
# Leave BLANK for local development — bot auto-switches to polling mode
# Set to your Render app URL for production:
# WEBHOOK_URL=https://telegram-finance_bot.onrender.com
WEBHOOK_URL=
